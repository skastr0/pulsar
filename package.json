{
  "name": "@skastr0/pulsar",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Pulsar — a library of provable preference signals with deterministic scoring for LLM-aligned decision-making",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "bun packages/cli/src/bin.ts",
    "build": "turbo run build",
    "build:cli": "bun scripts/build-cli.ts",
    "install:local": "bun scripts/install.ts",
    "test": "turbo run test",
    "benchmark:score-honesty": "bun docs/explorations/default-score-honesty-benchmark-harness.ts",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "turbo": "^2.3.0",
    "typescript": "^5.8.0"
  },
  "packageManager": "bun@1.2.0",
  "engines": {
    "bun": ">=1.2.0"
  }
}
