{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@skastr0/pulsar-core": ["../../../../packages/core/dist/index.d.ts"],
      "@skastr0/pulsar-core/signal": ["../../../../packages/core/dist/signal-api.d.ts"],
      "effect": ["../../../../packages/core/node_modules/effect/dist/dts/index.d.ts"],
      "effect/*": ["../../../../packages/core/node_modules/effect/dist/dts/*.d.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
