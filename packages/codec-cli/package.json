{
  "name": "@taste-codec/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Taste Codec CLI — taste score, taste bisect",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
