    "@taste-codec/rs-pack": "workspace:*",
    "@taste-codec/shared-signals": "workspace:*",
    "@taste-codec/ts-pack": "workspace:*",
    "effect": "^3.0.0",
    "simple-git": "^3.25.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
