{
  "name": "@skastr0/pulsar-ts-pack",
  "version": "0.1.4",
  "type": "module",
  "description": "TypeScript signal pack for Pulsar",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skastr0/pulsar.git",
    "directory": "packages/ts-pack"
  },
  "homepage": "https://github.com/skastr0/pulsar#readme",
  "bugs": {
    "url": "https://github.com/skastr0/pulsar/issues"
  },
  "keywords": [
    "pulsar",
    "typescript",
    "signals",
    "static-analysis"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/__tests__",
    "!dist/__tests__/**"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "test": "bun test ./src",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@skastr0/pulsar-core": "0.1.4",
    "@skastr0/pulsar-shared-signals": "0.1.4",
    "effect": "^3.0.0",
    "simple-git": "^3.25.0",
    "ts-morph": "^24.0.0"
  },
  "devDependencies": {
    "@skastr0/pulsar-project-module-nextjs": "workspace:*",
    "@skastr0/pulsar-signal-test-support": "workspace:*",
    "typescript": "^5.8.0"
  }
}
