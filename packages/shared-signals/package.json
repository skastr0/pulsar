{
  "name": "@skastr0/pulsar-shared-signals",
  "version": "0.1.1",
  "type": "module",
  "description": "Language-agnostic shared signals for Pulsar",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skastr0/pulsar.git",
    "directory": "packages/shared-signals"
  },
  "homepage": "https://github.com/skastr0/pulsar#readme",
  "bugs": {
    "url": "https://github.com/skastr0/pulsar/issues"
  },
  "keywords": [
    "pulsar",
    "signals",
    "repository-health",
    "static-analysis"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/__tests__",
    "!dist/__tests__/**"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "test": "bun test ./src --pass-with-no-tests",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@skastr0/pulsar-core": "0.1.1",
    "effect": "^3.0.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  }
}
