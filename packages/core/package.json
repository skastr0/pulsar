{
  "name": "@skastr0/pulsar-core",
  "version": "0.1.1",
  "type": "module",
  "description": "Signal interface, registry, scoring engine, and pulsar vector for Pulsar",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skastr0/pulsar.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/skastr0/pulsar#readme",
  "bugs": {
    "url": "https://github.com/skastr0/pulsar/issues"
  },
  "keywords": [
    "pulsar",
    "repository-health",
    "scoring",
    "signals",
    "static-analysis"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./backpressure": {
      "types": "./dist/backpressure.d.ts",
      "default": "./dist/backpressure.js"
    },
    "./calibration": {
      "types": "./dist/calibration.d.ts",
      "default": "./dist/calibration.js"
    },
    "./factors": {
      "types": "./dist/factors.d.ts",
      "default": "./dist/factors.js"
    },
    "./elicitation": {
      "types": "./dist/elicitation.d.ts",
      "default": "./dist/elicitation.js"
    },
    "./observer": {
      "types": "./dist/observer.d.ts",
      "default": "./dist/observer.js"
    },
    "./reference-data": {
      "types": "./dist/reference-data.d.ts",
      "default": "./dist/reference-data.js"
    },
    "./ai-facts": {
      "types": "./dist/ai-facts.d.ts",
      "default": "./dist/ai-facts.js"
    },
    "./routing": {
      "types": "./dist/routing.d.ts",
      "default": "./dist/routing.js"
    },
    "./scoring": {
      "types": "./dist/scoring.d.ts",
      "default": "./dist/scoring.js"
    },
    "./state": {
      "types": "./dist/state-paths.d.ts",
      "default": "./dist/state-paths.js"
    },
    "./shared-signals": {
      "types": "./dist/shared-signals.d.ts",
      "default": "./dist/shared-signals.js"
    },
    "./signal": {
      "types": "./dist/signal-api.d.ts",
      "default": "./dist/signal-api.js"
    },
    "./time-series": {
      "types": "./dist/time-series.d.ts",
      "default": "./dist/time-series.js"
    },
    "./vector": {
      "types": "./dist/vector.d.ts",
      "default": "./dist/vector.js"
    }
  },
  "files": [
    "dist",
    "!dist/__tests__",
    "!dist/__tests__/**",
    "routing-patterns",
    "presets",
    "quiz-items"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "test": "bun test ./src",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "effect": "^3.0.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  }
}
